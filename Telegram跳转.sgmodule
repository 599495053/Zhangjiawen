#!name=Telegram 跳转
#!desc=将 https://t.me/... 重定向到指定 Telegram 客户端
#!author=zjw
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png
#!arguments=选择跳转客户端:Telegram
#!arguments-desc=客户端 可选：Telegram / Swiftgram / Turrit / iMe / Nicegram / Lingogram
[Script]
Telegram 链接重定向 = type=http-request,pattern=^https?:\/\/t\.me\/.+,script-path=https://raw.githubusercontent.com/599495053/loon-/refs/heads/main/telegramtz.js,argument=CLIENT={{CLIENT}},timeout=10

[MITM]
hostname = %APPEND% t.me